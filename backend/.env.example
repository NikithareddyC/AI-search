# ============================================================================
# AI CONTENT & GROWTH PLATFORM - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this to .env and fill in your actual values!

# ============================================================================
# DATABASE
# ============================================================================
# Option 1: PostgreSQL Local
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_content_platform

# Option 2: Neon DB Free Tier (recommended)
# DATABASE_URL=postgresql://[user:password@]db.neon.tech/[dbname]

# ============================================================================
# LLM PROVIDERS (Choose at least one)
# ============================================================================

# OpenAI GPT-4 (RECOMMENDED - has free $5 credits)
OPENAI_API_KEY=sk_test_your_key_here
# Get free credits: https://platform.openai.com/account/billing/overview

# Anthropic Claude (Optional)
ANTHROPIC_API_KEY=

# Ollama Local (Optional - free, runs locally)
OLLAMA_BASE_URL=http://localhost:11434

DEFAULT_LLM=openai

# ============================================================================
# LINKEDIN - AUTO-POSTING & GROWTH TRACKING
# ============================================================================
# Your LinkedIn email and password for authentication
LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_password

# Enable/Disable auto-posting
AUTO_POST_ENABLED=True

# Posting schedule: daily, 3times_weekly, weekly
POST_SCHEDULE=daily

# Number of posts per week
POSTS_PER_WEEK=4

# Optimal posting time (24-hour format EST)
OPTIMAL_POST_TIME_EST=09:00

# ============================================================================
# SEARCH & RESEARCH
# ============================================================================

# Google Search API (Optional - for better research)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Max research sources to analyze per topic
MAX_RESEARCH_SOURCES=20

# Max content variations to create per topic
MAX_CONTENT_VARIATIONS=4

# ============================================================================
# REDIS CACHE (Optional)
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# SERVER & DEVELOPMENT
# ============================================================================
# Server configuration
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Debug mode (set to False in production)
DEBUG=True

# Log level: INFO, DEBUG, WARNING, ERROR
LOG_LEVEL=INFO

# JWT Secret (change this in production!)
JWT_SECRET=your-super-secret-key-change-this

# ============================================================================
# FEATURES
# ============================================================================
# Enable engagement optimization
ENGAGEMENT_OPTIMIZATION_ENABLED=True

# Topics to learn per week
TOPICS_TO_LEARN_PER_WEEK=1

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 1. Get OpenAI Free Credits:
#    - Go to: https://platform.openai.com/account/billing/overview
#    - Add your payment method (won't charge for free tier)
#    - Copy your API key here
#
# 2. LinkedIn Credentials:
#    - Use your LinkedIn email and password
#    - These are used for automated posting via linkedin-api
#    - Keep secure! Never commit this file with real credentials.
#
# 3. (Optional) Google Search API:
#    - Go to https://console.cloud.google.com
#    - Create a custom search engine
#    - Add API key here for enhanced research
#
# 4. (Optional) Neon DB:
#    - Go to https://console.neon.tech
#    - Create free PostgreSQL database
#    - Copy connection string here
